SYNCSEMPHONE_ENV=production
SYNCSEMPHONE_DISABLE_AUTH=0
SYNCSEMPHONE_COOKIE_SECURE=1
SYNCSEMPHONE_SESSION_MAX_AGE_SECONDS=43200
SYNCSEMPHONE_ENABLE_DOCS=0

# Required in production (32+ chars)
SYNCSEMPHONE_SESSION_SECRET=CHANGE_ME_MIN_32_CHARS

# Generate with: python3 infra/tools/generate_password_hash.py --username admin --password 'strong-password'
SYNCSEMPHONE_AUTH_PASSWORD_HASHES_JSON={"admin":"pbkdf2_sha256$310000$REPLACE_SALT$REPLACE_DIGEST"}

# Domain constraints
SYNCSEMPHONE_ALLOWED_HOSTS=syncsem.senju-tech.com,127.0.0.1,localhost
SYNCSEMPHONE_CORS_ORIGINS=https://syncsem.senju-tech.com
SYNCSEMPHONE_FRAME_ANCESTORS='self' https://syncsem.senju-tech.com

# Optional metadata DB (leave empty to disable lexicon metadata extensions)
SYNCSEMPHONE_META_DB_URL=
